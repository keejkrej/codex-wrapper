{
  "name": "@codex-wrapper/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "effect": "https://pkg.pr.new/Effect-TS/effect-smol/effect@8881a9b",
      "@effect/platform-node": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/platform-node@8881a9b",
      "@effect/sql-sqlite-bun": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/sql-sqlite-bun@8881a9b",
      "@effect/vitest": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/vitest@8881a9b",
      "@effect/language-service": "0.75.1",
      "@types/bun": "^1.3.9",
      "@types/node": "^24.10.13",
      "tsdown": "^0.20.3",
      "typescript": "^5.7.3",
      "vitest": "^4.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --filter=@t3tools/code",
    "dev:web": "turbo run dev --filter=@t3tools/code",
    "dev:desktop": "turbo run dev:tauri --filter=@t3tools/code",
    "build": "turbo run build",
    "build:desktop": "turbo run build:tauri --filter=@t3tools/code",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --report-unused-disable-directives .",
    "test": "turbo run test",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "turbo": "^2.3.3",
    "vitest": "catalog:"
  },
  "overrides": {
    "vite": "^8.0.0"
  },
  "engines": {
    "bun": "^1.3.9",
    "node": "^24.13.1"
  },
  "packageManager": "bun@1.3.9",
  "msw": {
    "workerDirectory": [
      "apps/code/public"
    ]
  }
}
