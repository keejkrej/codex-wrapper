{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "T3 Chat",
  "version": "0.0.13",
  "identifier": "gg.ping.t3chat.tauri",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:5733",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "T3 Chat (Alpha)",
        "width": 1100,
        "height": 780,
        "minWidth": 840,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
